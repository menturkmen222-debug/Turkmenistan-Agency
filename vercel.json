{
  "buildCommand": "pnpm --filter @workspace/api-server run build && pnpm --filter @workspace/yenil run build",
  "outputDirectory": "artifacts/yenil/dist/public",
  "installCommand": "pnpm install --frozen-lockfile",
  "framework": null,
  "functions": {
    "api/index.mjs": {
      "maxDuration": 30,
      "includeFiles": "artifacts/api-server/dist/**"
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
